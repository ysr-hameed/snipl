{
  "name": "@snipl/official-registry",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Official built-in snippet registry for snipl — TypeScript utility modules including sleep, retry, debounce, throttle, memoize, deep-clone, clamp, and slugify.",
  "keywords": [
    "snippet",
    "snippets",
    "typescript",
    "utility",
    "sleep",
    "retry",
    "debounce",
    "throttle",
    "memoize",
    "deep-clone",
    "clamp",
    "slugify",
    "registry",
    "source-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysr-hameed/snipl.git"
  },
  "bugs": {
    "url": "https://github.com/ysr-hameed/snipl/issues"
  },
  "main": "./dist/src/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "!dist/src/**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "types": "./dist/src/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@snipl/registry-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
