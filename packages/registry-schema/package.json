{
  "name": "@snipl/registry-schema",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "description": "Zod schema definitions and validation for the snipl registry — registry items, manifests, configs, integrity verification, and SPDX license checks.",
  "keywords": [
    "snippet",
    "snippets",
    "typescript",
    "zod",
    "schema",
    "validation",
    "registry",
    "manifest",
    "spdx",
    "integrity"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysr-hameed/snipl.git"
  },
  "bugs": {
    "url": "https://github.com/ysr-hameed/snipl/issues"
  },
  "main": "./dist/src/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "!dist/src/**/*.tsbuildinfo"
  ],
  "publishConfig": {
    "types": "./dist/src/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
